# ============================================================
# Wallet Wellness — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env — it's already in .gitignore
# ============================================================

# App metadata (safe to expose)
VITE_APP_NAME=Wallet Wellness
VITE_APP_VERSION=1.0.0

# === OPTIONAL: Analytics (e.g. Posthog, Umami) ===
# VITE_ANALYTICS_KEY=your_key_here

# === OPTIONAL: Future backend / Supabase ===
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key_here

# === OPTIONAL: Currency API ===
# VITE_CURRENCY_API_KEY=your_key_here
